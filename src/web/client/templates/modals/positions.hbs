<div class="row">
  <div class="col-12">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-dark">
          <tr>
            <th>Date</th>
            <th>Symbol</th>
            <th>Side</th>
            <th>Size</th>
            <th>unrealisedPnl</th>
            <th>avgPrice</th>
            <th>Changes</th>
            <th>Del</th>
          </tr>
        </thead>
        <tbody>
          {{#each positions}}
            <tr class="position-item cursor-pointer{{#if (gt unrealisedPnl 0)}} table-success{{else}} table-danger{{/if}}" data-symbol="{{symbol}}">
              <td>{{formatDate updatedTime}}</td>
              <td>{{symbol}}</td>
              <td class="{{#if (eq side 'Buy')}}text-success{{else}}text-danger{{/if}}">
                {{#if (eq side 'Buy')}}Long{{else}}Short{{/if}}
              </td>
              <td>
                {{formatPrice positionValue}}$
              </td>
              <td class="{{#if (gt unrealisedPnl 0)}}text-success{{else}}text-danger{{/if}}">
                {{formatPrice unrealisedPnl}}$
              </td>
              <td>
                {{formatPrice avgPrice 4}}$
              </td>
              <td class="{{#if (gt unrealisedPnl 0)}}text-success{{else}}text-danger{{/if}}">
                {{#if (gt unrealisedPnl 0)}}+{{else}}-{{/if}}{{changePercent markPrice avgPrice}}%
              </td>
              <td>
                <button type="button" class="btn btn-sm" data-symbol="{{symbol}}" data-action="closePosition" data-side="{{side}}" data-qty="{{size}}">🗑</button>
              </td>
            </tr>
          {{else}}
            <tr>
              <td colspan="12" class="text-center">No positions found</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>