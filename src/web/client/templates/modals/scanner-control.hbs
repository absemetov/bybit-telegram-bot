{{#if loading}}
  <div class="text-center py-3">
    <div class="spinner-border spinner-border-sm text-primary"></div>
  </div>
{{else}}
  <div class="text-center">
    <div class="mb-3">
      <span class="fw-bold">Статус:</span>
      {{#if scannerRunning}}
        <span class="badge bg-success">Работает</span>
      {{else}}
        <span class="badge bg-danger">Остановлен</span>
      {{/if}}
    </div>
    <button class="btn {{#if scannerRunning}}btn-danger{{else}}btn-success{{/if}}" data-action="toggleScanner">
      {{#if scannerRunning}}⏹️ Остановить сканер{{else}}▶️ Запустить сканер{{/if}}
    </button>
  </div>
{{/if}}